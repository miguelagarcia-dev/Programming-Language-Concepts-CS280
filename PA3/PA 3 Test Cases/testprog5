PROGRAM Cube;
VAR
	(*Illegal Operand Type for Sign Operator.*)
	r, a, p, b : REAL := 0; 
	str: string := 'Hello World!     ';
	st1, st2 : string;
	ch : char := +'A';
	f : boolean := true	;
BEGIN
	st1 := -str;
	if ( ch = 'A' ) THEN
	  st2 := st1 + ' Welcome!!';
	(*Display the results*)
	WRITELN ( 'The output results are ' , ch, ' ', f, ', ', st2,',');
END.
