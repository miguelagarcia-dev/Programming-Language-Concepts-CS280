program myWork;
const
   epsilon = 0.0001;
   factor = 4;
var
	{Testing reading integer and real values}
	p, k : real; 
	i, j : integer:= 7;	
	
begin
	writeln('Enter two integers and one real values:');
	readln (i, j, p);{values 19, 3, 7.35}
	
	k := i div j;
	j := i mod factor;
	
	{Display the results}
	writeln  ('The values for p, i, j, and k: ' , p, ', ', i, ', ', j, ', ', k);
end.
